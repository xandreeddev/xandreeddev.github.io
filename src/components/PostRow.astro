---
import { isoDate, type Post } from '../utils/posts';

interface Props {
  post: Post;
  /** Link prefix — the drafts index points rows at /drafts instead. */
  base?: string;
}

const { post, base = '/posts' } = Astro.props;
---

<a class="post-row" href={`${base}/${post.id}/`}>
  <time datetime={post.data.pubDate.toISOString()}>{isoDate(post.data.pubDate)}</time>
  <span>
    <span class="title">
      {post.data.title}
      {post.data.draft && <span class="draft-badge">draft</span>}
    </span>
    <span class="desc">{post.data.description}</span>
  </span>
</a>

<style>
  .post-row .title,
  .post-row .desc {
    display: block;
  }
</style>
