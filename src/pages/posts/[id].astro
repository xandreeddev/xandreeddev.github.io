---
import { render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Toc from '../../components/Toc.astro';
import SeriesBanner from '../../components/SeriesBanner.astro';
import { getPosts, getAllPosts, isoDate, readingTime, seriesSlug, toSeriesParts, type Post, type SeriesPart } from '../../utils/posts';

export async function getStaticPaths() {
  const posts = await getPosts(); // live pages to build
  const all = await getAllPosts(); // full arc (live + draft) for series banners
  return posts.map((post, i) => {
    const series = post.data.series;
    return {
      params: { id: post.id },
      props: {
        post,
        newer: posts[i - 1] ?? null,
        older: posts[i + 1] ?? null,
        seriesName: series?.name ?? null,
        seriesSlug: series ? seriesSlug(series.name) : null,
        seriesParts: series ? toSeriesParts(all, series.name, post.id) : [],
      },
    };
  });
}

interface Props {
  post: Post;
  newer: Post | null;
  older: Post | null;
  seriesName: string | null;
  seriesSlug: string | null;
  seriesParts: SeriesPart[];
}

const { post, newer, older, seriesName, seriesSlug, seriesParts } = Astro.props;
const { Content, headings } = await render(post);
const minutes = readingTime(post.body ?? '');
---

<Base title={`${post.data.title} — xandreed`} description={post.data.description} ogType="article">
  <div class="container">
    <article class="post-wrap">
      <header class="post-header">
        <p class="meta">
          <time datetime={post.data.pubDate.toISOString()}>{isoDate(post.data.pubDate)}</time>
          <span class="sep" aria-hidden="true">·</span>
          <span>{minutes} min read</span>
          {post.data.tags.length > 0 && <span class="sep" aria-hidden="true">·</span>}
          {post.data.tags.map((tag) => <a class="tag" href={`/tags/${tag}/`}>{tag}</a>)}
          {post.data.draft && <span class="draft-badge">draft</span>}
        </p>
        <h1>{post.data.title}</h1>
        <p class="lede">{post.data.description}</p>
      </header>
      {seriesName && seriesSlug && <SeriesBanner name={seriesName} slug={seriesSlug} parts={seriesParts} />}
      <Toc headings={headings} />
      <div class="prose">
        <Content />
      </div>
      <footer class="post-footer">
        <p class="cta">
          I build efferent in public — follow along on <a href="https://x.com/xandreeddev">X</a> or
          read the source on <a href="https://github.com/xandreeddev/efferent">GitHub</a>.
        </p>
        <nav class="post-nav" aria-label="Adjacent posts">
          <span>
            {
              older && (
                <a href={`/posts/${older.id}/`}>
                  <span class="dir">← older</span>
                  <span class="t">{older.data.title}</span>
                </a>
              )
            }
          </span>
          <span class="next">
            {
              newer && (
                <a href={`/posts/${newer.id}/`}>
                  <span class="dir">newer →</span>
                  <span class="t">{newer.data.title}</span>
                </a>
              )
            }
          </span>
        </nav>
      </footer>
    </article>
  </div>
</Base>
